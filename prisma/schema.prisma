generator client {
  provider = "prisma-client-js"
 
}

datasource db {
  provider = "postgresql"
 url=postgresql://neondb_owner:npg_aN19JrLUKbVs@ep-frosty-wave-aqdyog5z-pooler.c-8.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
}

model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  password String

  endpoints Endpoint[]
  refreshToken RefreshToken[]
  events     Event[]

}

model Endpoint {
  id   Int  @id @default(autoincrement())
  url  String
  secret String
  name  String?
  userId Int
  createdAt DateTime @default(now())   
  updatedAt DateTime @updatedAt        
  user User @relation(fields: [userId], references: [id])
  events Event[]
}

model Event {
  id           Int          @id @default(autoincrement())
  type         String
  payload      Json
  status       String       @default("pending")
  userId       Int
  endpointId   Int?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         User         @relation(fields: [userId], references: [id])
  endpoint     Endpoint?    @relation(fields: [endpointId], references: [id])
  deliveryLogs DeliveryLog[]
}

model DeliveryLog {
  id           Int      @id @default(autoincrement())
  status       String
  attempt      Int
  responseCode Int?
  errorMessage String?
  eventId      Int
  createdAt    DateTime @default(now())
  event        Event    @relation(fields: [eventId], references: [id])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  revoked   Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}